# Copy this file to .env and fill in real values before starting the backend.

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:<password>@localhost/football_db

# Required — signs the JWT auth tokens. Generate a strong value with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=

# Where the frontend runs (used for CORS and links in emails)
FRONTEND_URL=http://localhost:5173

# Optional email delivery. When neither Resend nor SMTP is configured,
# verification/reset links are printed to the server console instead.
# RESEND_API_KEY=
# RESEND_FROM=CoachHub <onboarding@resend.dev>
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@coachhub.com
